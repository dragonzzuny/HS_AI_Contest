    "조문": {
      "조": [
        {
          "조문번호": [
            "000100",
            "000100"
          ],
          "조제목": "목적",
          "조내용": "제1조(목적) 이 조례는「지역보건법」제34조에 따른 과태료의 부과·징수에 관하여 필요한 사항을 규정함을 목적으로 한다. (개정 2019. 11. 15)",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "000200",
            "000200"
          ],
          "조제목": "과태료 부과·징수",
          "조내용": "제2조(과태료 부과·징수) 과태료는 화성시장(이하 “시장”이라 한다)이 부과·징수한다.",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "000300",
            "000300"
          ],
          "조제목": "과태료 부과대상",
          "조내용": "제3조(과태료 부과대상) 과태료 부과대상자는 다음 각 호의 어느 하나에 해당하는 자로 한다. (개정 2019. 11. 15, 2023. 9. 26)1. 「지역보건법」(이하 “법”이라 한다) 제22조제3항을 위반하여 정보 또는 자료를 파기하지 않은 자2. 법 제23조에 따른 신고를 하지 않거나 거짓으로 신고하고 건강검진등을 한 자3. 법 제29조를 위반하여 동일 명칭을 사용한 자",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "000400",
            "000400"
          ],
          "조제목": "과태료 부과기준",
          "조내용": "제4조(과태료 부과기준) 법 제34조에 따른 과태료의 부과기준은 별표와 같다. (개정 2019. 11. 15, 2023. 9. 26)",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "000500",
            "000500"
          ],
          "조제목": "처분의 사전통지 및 의견제출",
          "조내용": "제5조(처분의 사전통지 및 의견제출)① 시장이 법 제34조에 따라 과태료를 부과하고자 할 때에는「질서위반행위규제법」제16조에 따라 미리 처분대상자에게 처분의 사전통지를 하여야 한다. (개정 2019. 11. 15, 2023. 9. 26)② 시장은 제1항에 따라 처분의 사전통지를 할 때에는 10일 이상의 기간을 정하여 처분대상자에게 의견진술의 기회를 주어야 한다. 이 경우 처분의 사전통지는 별지 제1호서식으로 한다.③ 처분대상자는 별지 제2호서식에 따라 서면·구술 또는 정보통신망을 이용하여 의견을 제출할 수 있으며, 지정된 기일까지 의견을 제출하지 아니한 경우에는 의견이 없는 것으로 본다.",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "000600",
            "000600"
          ],
          "조제목": "과태료 부과처분 통지 등",
          "조내용": "제6조(과태료 부과처분 통지 등)① 시장은 법 제34조에 따라 과태료를 부과할 때 별지 제3호서식의 과태료 부과처분 통지서를 처분대상자에게 통지하여야 한다. (개정 2019. 11. 15)② 과태료의 납부기한은 과태료 납부고지서를 발급한 날부터 30일 이내로 한다.③ 시장은 납부기한까지 과태료를 납부하지 아니한 경우에는 납부기한이 지난날부터 10일 이내에 15일간의 납부기간을 정하여 별지 제4호서식의 과태료 납부 독촉장을 발부하여야 한다.",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "000700",
            "000700"
          ],
          "조제목": "이의제기 및 법원통보",
          "조내용": "제7조(이의제기 및 법원통보)① 제6조제1항에 따라 과태료 처분을 받은 자가 이에 대하여 불복이 있을 때에는 그 처분의 고지를 받은 날부터 60일 이내에 별지 제5호서식을 작성하여 시장에게 이의를 제기할 수 있다.② 제1항에 따라 이의제기가 있는 경우 시장은 14일 이내에 별지 제6호서식의 과태료 처분에 대한 이의제기 통보서에 따라 관할 법원에 그 사실을 통보하여야 하며, 이의를 제기한 자에게도 법원에 통보한 사실을 통지하여야 한다.",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "000800",
            "000800"
          ],
          "조제목": "과태료의 부과처분의 정정 등",
          "조내용": "제8조(과태료의 부과처분의 정정 등) 시장은 과태료부과 처분이 위법 또는 부당한 것으로 확인된 때에는 즉시 그 처분을 취소하거나 변경하여야 하며, 이 경우 과태료처분 대상자에게 별지 제7호서식에 따라 통지하여야 한다.",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "000900",
            "000900"
          ],
          "조제목": "과태료 부과·징수대장 관리",
          "조내용": "제9조(과태료 부과·징수대장 관리) 시장은 과태료의 부과·징수 및 수납에 관한 사항 등을 별지 제8호서식에 따라 기록·관리하여야 한다.",
          "조문여부": "Y"
        },
        {
          "조문번호": [
            "001000",
            "001000"
          ],
          "조제목": "과태료의 귀속",
          "조내용": "제10조(과태료의 귀속) 수납되는 과태료는 화성시의 수입으로 한다.",
          "조문여부": "Y"
        },
